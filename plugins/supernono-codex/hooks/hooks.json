{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "shell_command|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/pre-tool-use.js",
            "command_windows": "C:\\PROGRA~1\\nodejs\\node.exe ${PLUGIN_ROOT}\\hooks\\pre-tool-use.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      },

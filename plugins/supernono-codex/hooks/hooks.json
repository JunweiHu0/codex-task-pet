{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/pre-tool-use.js",
            "command_windows": "node .\\hooks\\pre-tool-use.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/pre-tool-use.js",
            "command_windows": "node .\\hooks\\pre-tool-use.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/pre-tool-use.js",
            "command_windows": "node .\\hooks\\pre-tool-use.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/post-tool-use.js",
            "command_windows": "node .\\hooks\\post-tool-use.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/permission-request.js",
            "command_windows": "node .\\hooks\\permission-request.js",
            "timeout": 5,
            "statusMessage": "Updating SuperNoNo"
          }
        ]
      }
    ]
  }
}
